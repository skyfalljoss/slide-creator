# Copy this file to .env and replace every change-me value before deployment.
POSTGRES_PASSWORD=change-me-postgres
ONLYOFFICE_JWT_SECRET=change-me-onlyoffice

# Browser-visible origin and ONLYOFFICE virtual path. Use the internal HTTPS DNS
# name in production, without a trailing slash.
PUBLIC_APP_URL=http://localhost
ONLYOFFICE_PUBLIC_URL=http://localhost/onlyoffice
WEB_PORT=80

STORAGE_PROVIDER=local
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCS_BUCKET=your-private-deck-bucket
BACKUP_GCS_URI=gs://your-private-backup-bucket/slideforge

AI_PROVIDER=local
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CITI_SSO_ENABLED=false
